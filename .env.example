# Copy to .env and fill in VALUES. The Taskfile loads this (never the ambient shell).
# These are secrets — real values live only here (gitignored), never in config.toml,
# never in code, never printed. Use obvious fakes in any example.

# Telegram bot token (used by `send` and to verify the inbound webhook secret header):
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# HMAC shared secret for the generic inbound hook (POST /hook/hook):
MESSENGER_HOOK_SECRET=YOUR_STRONG_SHARED_SECRET

# Bearer token the HTTP API (POST /send, GET /inbox) requires (optional; loopback dev
# can leave serveTokenEnv empty in config.toml):
MESSENGER_SERVE_TOKEN=YOUR_API_BEARER_TOKEN
