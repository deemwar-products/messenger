# Example env for messenger. Export these in your shell/service environment — the CLI
# reads the process environment directly (there is no Taskfile / dotenv loader).
# These are secrets — real values live only in your environment or the age vault,
# never in config.toml, never in code, never printed. Use obvious fakes in examples.

# Telegram bot token (one per telegram channel; name it whatever you pass --token-env):
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# HMAC shared secret for a webhook channel (POST /webhook/<name>):
MESSENGER_HOOK_SECRET=YOUR_STRONG_SHARED_SECRET

# Bearer token the HTTP API (POST /send, GET /inbox) requires (optional; loopback dev
# can leave serveTokenEnv empty in config.toml):
MESSENGER_SERVE_TOKEN=YOUR_API_BEARER_TOKEN
